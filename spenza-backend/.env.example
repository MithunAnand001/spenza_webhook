PORT=3001
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=spenza_webhooks
JWT_SECRET=change_me_min_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_refresh_min_32_characters
JWT_REFRESH_EXPIRES_IN=30d
RABBITMQ_URL=amqp://your_user:your_pass@localhost:5672
RABBITMQ_QUEUE_WEBHOOK_EVENTS=webhook.events
RABBITMQ_QUEUE_RETRY=webhook.events.retry
RABBITMQ_EXCHANGE=webhook.exchange
CRYPTO_SECRET=change_me_exactly_32_chars_here!!
WEBHOOK_SIGNING_SECRET=change_me_signing_secret
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=5000